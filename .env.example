# ===========================================
# BM Wood Backend Configuration
# ===========================================
# Copy this file to .env.local and fill in your values

# MongoDB Connection
# For local development: mongodb://localhost:27017/bmwood
# For MongoDB Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bmwood
MONGODB_URI=mongodb://localhost:27017/bmwood

# JWT Secrets (Generate strong random strings)
# You can generate secrets using: openssl rand -base64 64
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production

# Email Configuration (Resend)
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=BM Wood <noreply@bmwood.tn>
ADMIN_EMAIL=contact@bmwood.tn

# Application URL
# Used for generating links in emails and PDF documents
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
